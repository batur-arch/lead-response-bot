# ============================================================
# Lead Response Bot - Environment Variables
# Copy this to Vercel Project Settings → Environment Variables
# DO NOT commit a real .env file to GitHub
# ============================================================

# --- Twilio ---
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# --- OpenAI ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_key_here

# --- Upstash Redis (US East region) ---
# Get from: https://console.upstash.com/ (create Redis DB in us-east-1)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# --- Client config (per-client; for v1 we hard-code first client here) ---
# BROKER_NAME is the HVAC/Roofing company name shown in SMS messages
BROKER_NAME=Iseri Demo HVAC
BROKER_EMAIL=batur@iseriagency.com
BROKER_CALENDAR_URL=https://calendly.com/iseri-demo/free-estimate

# --- Compliance ---
# Webhook secret for inbound lead form (broker sends with this key in header)
LEAD_WEBHOOK_SECRET=generate_a_random_32_char_string_here

# Environment (production / staging / dev)
NODE_ENV=production
